# Production Environment Configuration
# Copy this file to .env and update with your actual values

# ===========================================
# APPLICATION CONFIGURATION
# ===========================================
ENVIRONMENT=production
DEBUG=false
SECRET_KEY=your-super-secret-key-change-this-immediately-64-characters-long
JWT_SECRET_KEY=your-jwt-secret-key-change-this-immediately-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===========================================
# DOMAIN AND HTTPS
# ===========================================
DOMAIN=yourdomain.com
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
DATABASE_URL=postgresql://deepfake_user:deepfake_password@postgres:5432/deepfake_db
POSTGRES_DB=deepfake_db
POSTGRES_USER=deepfake_user
POSTGRES_PASSWORD=deepfake_password_change_this

# ===========================================
# REDIS CONFIGURATION
# ===========================================
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ===========================================
# FILE STORAGE
# ===========================================
UPLOAD_DIR=/app/uploads
RESULTS_DIR=/app/results
MODEL_DIR=/app/models
MAX_FILE_SIZE=104857600
MAX_VIDEO_DURATION=300

# ===========================================
# MODEL CONFIGURATION
# ===========================================
DEFAULT_MODEL_VERSION=2.0.0
ENABLE_AUDIO_ANALYSIS=true
ENABLE_FACIAL_ANALYSIS=true
DEFAULT_CONFIDENCE_THRESHOLD=0.5

# ===========================================
# RATE LIMITING
# ===========================================
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000
RATE_LIMIT_PER_DAY=10000

# ===========================================
# SECURITY
# ===========================================
BCRYPT_ROUNDS=12
SESSION_TIMEOUT=3600
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_DURATION=900

# ===========================================
# MONITORING AND LOGGING
# ===========================================
LOG_LEVEL=INFO
SENTRY_DSN=your-sentry-dsn-here
PROMETHEUS_ENABLED=true
METRICS_PORT=8000

# ===========================================
# EMAIL CONFIGURATION
# ===========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@yourdomain.com
SMTP_PASSWORD=your-app-password
SMTP_TLS=true
SMTP_SSL=false
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=DeepFake Recognition System

# ===========================================
# BACKUP CONFIGURATION
# ===========================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=your-backup-bucket
BACKUP_S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# ===========================================
# SSL/TLS
# ===========================================
SSL_CERT_PATH=/etc/nginx/ssl/fullchain.pem
SSL_KEY_PATH=/etc/nginx/ssl/privkey.pem
SSL_CHAIN_PATH=/etc/nginx/ssl/chain.pem

# ===========================================
# API CONFIGURATION
# ===========================================
API_RATE_LIMIT=1000
API_TIMEOUT=300
API_MAX_CONNECTIONS=100
API_WORKERS=4

# ===========================================
# FRONTEND CONFIGURATION
# ===========================================
REACT_APP_API_URL=https://yourdomain.com/api
REACT_APP_WS_URL=wss://yourdomain.com/ws
REACT_APP_VERSION=2.0.0

# ===========================================
# DEVELOPMENT OVERRIDES
# ===========================================
# Uncomment these for development
# ENVIRONMENT=development
# DEBUG=true
# ALLOWED_ORIGINS=http://localhost:3000
# REACT_APP_API_URL=http://localhost:8000
